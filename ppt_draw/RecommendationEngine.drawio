<mxfile host="Electron" agent="Claude" version="1.0">
  <diagram id="recommendation_engine" name="智能分级推荐引擎">
    <mxGraphModel dx="1200" dy="1400" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="800" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- 标题 -->
        <mxCell id="title" value="智能分级推荐引擎：兼顾热度、质量与多样性的分级推荐策略" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontStyle=1;align=center;" parent="1" vertex="1">
          <mxGeometry x="50" y="30" width="900" height="50" as="geometry" />
        </mxCell>

        <!-- 用户请求 -->
        <mxCell id="user-request" value="用户请求推荐" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="100" y="120" width="120" height="60" as="geometry" />
        </mxCell>

        <!-- 用户画像分析 -->
        <mxCell id="user-profile" value="用户画像分析\n• 历史订单偏好\n• 收藏行为分析\n• 地理位置偏好\n• 价格范围偏好" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=10;align=left;" parent="1" vertex="1">
          <mxGeometry x="300" y="100" width="150" height="100" as="geometry" />
        </mxCell>

        <!-- 第一级：严格筛选 -->
        <mxCell id="level1-title" value="第一级：严格筛选策略" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="50" y="250" width="900" height="30" as="geometry" />
        </mxCell>

        <mxCell id="level1-criteria" value="严格筛选条件:\n• 评分 ≥ 4.5 星\n• 评价数量 ≥ 20 条\n• 活跃度高 (近30天有预订)\n• 完全匹配用户偏好" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;align=left;" parent="1" vertex="1">
          <mxGeometry x="80" y="300" width="180" height="80" as="geometry" />
        </mxCell>

        <mxCell id="level1-process" value="智能匹配算法\n• 地理偏好匹配\n• 价格区间筛选\n• 设施需求匹配\n• 房源类型偏好" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;align=left;" parent="1" vertex="1">
          <mxGeometry x="300" y="300" width="150" height="80" as="geometry" />
        </mxCell>

        <mxCell id="level1-check" value="结果数量\n≥ 目标数量\n(如6个)?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="500" y="300" width="100" height="80" as="geometry" />
        </mxCell>

        <mxCell id="level1-success" value="第一级成功\n返回高质量推荐" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="750" y="300" width="120" height="80" as="geometry" />
        </mxCell>

        <!-- 第二级：降级补充 -->
        <mxCell id="level2-title" value="第二级：降级补充策略" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="50" y="420" width="900" height="30" as="geometry" />
        </mxCell>

        <mxCell id="level2-criteria" value="放宽筛选条件:\n• 评分 ≥ 4.0 星\n• 评价数量 ≥ 10 条\n• 扩大地理范围\n• 适度放宽价格范围" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;align=left;" parent="1" vertex="1">
          <mxGeometry x="80" y="470" width="180" height="80" as="geometry" />
        </mxCell>

        <mxCell id="level2-process" value="加权推荐算法\n• 距离权重降低\n• 价格敏感度调整\n• 引入热门房源\n• 多样性保证" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;align=left;" parent="1" vertex="1">
          <mxGeometry x="300" y="470" width="150" height="80" as="geometry" />
        </mxCell>

        <mxCell id="level2-check" value="总结果数量\n≥ 目标数量?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="500" y="470" width="100" height="80" as="geometry" />
        </mxCell>

        <mxCell id="level2-success" value="第二级成功\n返回混合推荐" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="750" y="470" width="120" height="80" as="geometry" />
        </mxCell>

        <!-- 第三级：兜底策略 -->
        <mxCell id="level3-title" value="第三级：兜底保障策略" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="50" y="590" width="900" height="30" as="geometry" />
        </mxCell>

        <mxCell id="level3-criteria" value="最低门槛筛选:\n• 评分 ≥ 3.5 星\n• 有基本评价\n• 房源状态正常\n• 无地理限制" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;align=left;" parent="1" vertex="1">
          <mxGeometry x="80" y="640" width="180" height="80" as="geometry" />
