        <!-- 优势说明 -->
        <mxCell id="advantages" value="核心优势:\n✓ 解决冷启动问题\n✓ 处理数据稀疏性\n✓ 保证推荐质量\n✓ 确保充足数量\n✓ 兼顾个性化与多样性\n✓ 自适应降级机制" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;align=left;" parent="1" vertex="1">
