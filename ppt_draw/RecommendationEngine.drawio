        <!-- 用户画像到第一级 -->
        <mxCell id="edge2" value="开始推荐" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=classic;endFill=1;" parent="1" source="user-profile" target="level1-criteria" edge="1">
          <mxGeometry relative="1" as="geometry">
