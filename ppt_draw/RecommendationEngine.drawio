        <mxCell id="level3-process" value="通用推荐算法\n• 随机打散\n• 热门房源优先\n• 新房源曝光\n• 确保足够数量" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;align=left;" parent="1" vertex="1">
