        <!-- 最终输出 -->
        <mxCell id="final-output" value="最终推荐结果\n• 个性化排序\n• 多样性保证\n• 质量可控\n• 数量充足" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="750" y="640" width="120" height="80" as="geometry" />
        </mxCell>

        <!-- 连接线 -->
        <!-- 用户请求到用户画像 -->
        <mxCell id="edge1" value="分析用户行为" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=classic;endFill=1;" parent="1" source="user-request" target="user-profile" edge="1">
          <mxGeometry relative="1" as="geometry" />
