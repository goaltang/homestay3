            <mxPoint x="1000" y="355" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="level1_shield" value="" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;size=0.15;fillColor=#fff2cc;strokeColor=#d79b00;strokeWidth=2;" parent="1" vertex="1">
          <mxGeometry x="300" y="180" width="200" height="350" as="geometry" />
        </mxCell>
        <mxCell id="level1_text" value="&lt;b style=&quot;font-size: 18px;&quot;&gt;应用层锁&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&quot;font-size: 13px;&quot;&gt;核心作用：内存快速过滤&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#d79b00&quot;&gt;&lt;i&gt;ConcurrentHashMap&lt;/i&gt;&lt;/font&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
