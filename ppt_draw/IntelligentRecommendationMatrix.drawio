        <mxCell id="edge3" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=classic;endFill=1;" parent="1" source="user-profile" target="personalized-algorithm" edge="1">
          <mxGeometry relative="1" as="geometry" />
