        <mxCell id="edge4" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=classic;endFill=1;" parent="1" source="highlight-algorithm" target="highlight-innovation" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 核心价值总结 -->
        <mxCell id="core-value" value="核心价值：解决'如何发现好房源'、'如何发现热门房源'、'如何发现我喜欢的房源'三大问题\n技术创新：将算法思维贯穿从后端推荐到前端UI的全链路，实现真正的数据驱动用户体验" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;align=center;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="200" y="150" width="600" height="40" as="geometry" />
