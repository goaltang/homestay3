<mxfile host="Electron" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) draw.io/26.2.2 Chrome/134.0.6998.178 Electron/35.1.2 Safari/537.36" version="26.2.2">
  <diagram id="simplified_security_diagram" name="简化版-金融级交易安全设计">
    <mxGraphModel dx="1438" dy="828" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        
        <!-- 大标题 -->
        <mxCell id="title" value="金融级交易安全设计：三级纵深防御模型" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=24;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="350" y="40" width="500" height="40" as="geometry" />
        </mxCell>

        <!-- 进来的请求 -->
        <mxCell id="requests_in" value="大量并发请求&lt;br&gt;(e.g., 1000 req/s)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=14;" vertex="1" parent="1">
            <mxGeometry x="80" y="280" width="160" height="80" as="geometry" />
        </mxCell>
        
        <mxCell id="arrow_in" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=classic;endFill=1;strokeWidth=3;strokeColor=#333333;" edge="1" parent="1" source="requests_in">
            <mxGeometry relative="1" as="geometry">
                <mxPoint x="300" y="320" as="targetPoint" />
            </mxGeometry>
        </mxCell>

        <!-- 防御体系 - 使用一个大的容器来表示漏斗/过滤过程 -->
        <mxCell id="funnel_container" value="" style="shape=trapezoid;perimeter=trapezoidPerimeter;flipV=1;whiteSpace=wrap;html=1;fixedSize=1;size=0.2;fillColor=#f5f5f5;strokeColor=#666666;gradientColor=none;" vertex="1" parent="1">
            <mxGeometry x="300" y="150" width="600" height="340" as="geometry" />
        </mxCell>

        <!-- 第一级防御 -->
        <mxCell id="level1_box" value="&lt;b style=&quot;font-size: 16px;&quot;&gt;第一级：应用层锁&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;内存级过滤，成本最低，效率最高&lt;/span&gt;&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;BookingConflictService&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;align=center;" vertex="1" parent="1">
            <mxGeometry x="330" y="180" width="180" height="80" as="geometry" />
        </mxCell>
        <mxCell id="level1_arrow" value="过滤 99% 请求" style="edgeStyle=segmentEdgeStyle;endArrow=classic;html=1;curved=0;rounded=0;endSize=8;startSize=8;sourcePerimeterSpacing=0;targetPerimeterSpacing=0;strokeColor=#d79b00;strokeWidth=2;" edge="1" parent="1">
            <mxGeometry width="50" height="50" relative="1" as="geometry">
                <mxPoint x="420" y="270" as="sourcePoint" />
                <mxPoint x="420" y="320" as="targetPoint" />
            </mxGeometry>
        </mxCell>


        <!-- 第二级防御 -->
        <mxCell id="level2_box" value="&lt;b style=&quot;font-size: 16px;&quot;&gt;第二级：数据库悲观锁&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;行级锁定，保证数据操作原子性&lt;/span&gt;&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;SELECT ... FOR UPDATE&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=center;" vertex="1" parent="1">
            <mxGeometry x="510" y="250" width="180" height="80" as="geometry" />
        </mxCell>
        <mxCell id="level2_arrow" value="处理剩余 1%" style="edgeStyle=segmentEdgeStyle;endArrow=classic;html=1;curved=0;rounded=0;endSize=8;startSize=8;sourcePerimeterSpacing=0;targetPerimeterSpacing=0;strokeColor=#9673a6;strokeWidth=2;" edge="1" parent="1">
            <mxGeometry width="50" height="50" relative="1" as="geometry">
                <mxPoint x="470" y="225" as="sourcePoint" />
                <mxPoint x="510" y="290" as="targetPoint" />
            </mxGeometry>
        </mxCell>
        
        <!-- 第三级防御 -->
        <mxCell id="level3_box" value="&lt;b style=&quot;font-size: 16px;&quot;&gt;第三级：Serializable 事务&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;最高隔离级别，杜绝幻读&lt;/span&gt;&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;数据最终一致性&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=center;" vertex="1" parent="1">
            <mxGeometry x="690" y="320" width="180" height="80" as="geometry" />
        </mxCell>
        <mxCell id="level3_arrow" value="" style="edgeStyle=segmentEdgeStyle;endArrow=classic;html=1;curved=0;rounded=0;endSize=8;startSize=8;sourcePerimeterSpacing=0;targetPerimeterSpacing=0;strokeColor=#82b366;strokeWidth=2;" edge="1" parent="1">
            <mxGeometry width="50" height="50" relative="1" as="geometry">
                <mxPoint x="650" y="330" as="sourcePoint" />
                <mxPoint x="690" y="360" as="targetPoint" />
            </mxGeometry>
        </mxCell>

        <!-- 最终结果 -->
        <mxCell id="success_out" value="唯一成功订单" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="960" y="280" width="160" height="80" as="geometry" />
        </mxCell>
        <mxCell id="arrow_out" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=classic;endFill=1;strokeWidth=3;strokeColor=#333333;" edge="1" parent="1" source="funnel_container" target="success_out">
            <mxGeometry relative="1" as="geometry">
                <mxPoint x="900" y="320" as="sourcePoint" />
            </mxGeometry>
        </mxCell>

        <!-- 技术总结 -->
        <mxCell id="summary" value="技术核心：分层过滤 + 纵深防御，以最小代价实现金融级数据一致性" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=none;fontSize=16;fontStyle=1;" vertex="1" parent="1">
            <mxGeometry x="300" y="520" width="600" height="30" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile> 