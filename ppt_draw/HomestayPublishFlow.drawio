<mxfile host="Electron" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) draw.io/26.2.2 Chrome/134.0.6998.178 Electron/35.1.2 Safari/537.36" version="26.2.2">
  <diagram id="homestay_publish_flow" name="房东发布流程状态图">
    <mxGraphModel dx="2112" dy="719" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="900" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="start" value="房东开始发布" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="100" y="50" width="120" height="60" as="geometry" />
        </mxCell>
        <mxCell id="draft" value="草稿状态\n(DRAFT)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=12;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="100" y="170" width="120" height="80" as="geometry" />
        </mxCell>
        <mxCell id="draft-actions" value="• 填写基本信息\n• 上传图片\n• 设置价格\n• 添加设施\n• 保存草稿" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;align=left;" parent="1" vertex="1">
          <mxGeometry x="280" y="170" width="150" height="80" as="geometry" />
        </mxCell>
        <mxCell id="check-completeness" value="信息是否完整?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="110" y="320" width="100" height="80" as="geometry" />
        </mxCell>
        <mxCell id="pending" value="待审核状态\n(PENDING)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="100" y="460" width="120" height="80" as="geometry" />
        </mxCell>
        <mxCell id="review-process" value="管理员审核\n• 内容合规检查\n• 图片质量审核\n• 价格合理性审核\n• 设施信息核实" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;align=left;" parent="1" vertex="1">
          <mxGeometry x="280" y="460" width="150" height="80" as="geometry" />
        </mxCell>
        <mxCell id="review-decision" value="审核结果?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="110" y="600" width="100" height="80" as="geometry" />
        </mxCell>
        <mxCell id="published" value="已发布状态\n(PUBLISHED)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="350" y="750" width="120" height="80" as="geometry" />
        </mxCell>
        <mxCell id="published-features" value="发布后功能:\n• 用户可搜索\n• 接受预订\n• 收藏评价\n• 推荐展示" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=left;" parent="1" vertex="1">
          <mxGeometry x="520" y="750" width="130" height="80" as="geometry" />
        </mxCell>
        <mxCell id="rejected" value="已驳回状态\n(REJECTED)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="100" y="750" width="120" height="80" as="geometry" />
        </mxCell>
        <mxCell id="rejection-reasons" value="常见驳回原因:\n• 图片不清晰\n• 价格异常\n• 描述违规\n• 设施虚假\n• 联系信息错误" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;" parent="1" vertex="1">
          <mxGeometry x="280" y="750" width="140" height="80" as="geometry" />
        </mxCell>
        <mxCell id="inactive" value="非活跃状态\n(INACTIVE)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="700" y="460" width="120" height="80" as="geometry" />
        </mxCell>
        <mxCell id="inactive-reasons" value="非活跃原因:\n• 房东主动下架\n• 房源不可用\n• 违规下架\n• 系统暂停" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;align=left;" parent="1" vertex="1">
          <mxGeometry x="700" y="320" width="120" height="80" as="geometry" />
        </mxCell>
        <mxCell id="edge1" value="创建房源" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=classic;endFill=1;" parent="1" source="start" target="draft" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=classic;endFill=1;" parent="1" source="draft" target="draft-actions" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge3" value="提交审核" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=classic;endFill=1;" parent="1" source="draft" target="check-completeness" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge4" value="否 - 继续完善" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=classic;endFill=1;" parent="1" source="check-completeness" target="draft" edge="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="50" y="360" />
              <mxPoint x="50" y="210" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="edge5" value="是 - 提交审核" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=classic;endFill=1;" parent="1" source="check-completeness" target="pending" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge6" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=classic;endFill=1;" parent="1" source="pending" target="review-process" edge="1">
          <mxGeometry relative="1" as="geometry" />
