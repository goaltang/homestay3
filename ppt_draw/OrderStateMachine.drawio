        <mxCell id="edge6" value="取消" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=classic;endFill=1;strokeColor=#b85450;strokeWidth=2;" parent="1" source="unpaid" target="cancelled" edge="1">
          <mxGeometry relative="1" as="geometry" />
