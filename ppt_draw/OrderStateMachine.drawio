        <mxCell id="edge4" value="办理入住" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=classic;endFill=1;strokeColor=#82b366;strokeWidth=2;" parent="1" source="ready" target="checkedin" edge="1">
          <mxGeometry relative="1" as="geometry" />
