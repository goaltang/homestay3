        <mxCell id="core-features" value="核心特性" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="380" width="900" height="30" as="geometry" />
