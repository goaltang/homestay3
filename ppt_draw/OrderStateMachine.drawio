<mxfile host="Electron" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) draw.io/26.2.2 Chrome/134.0.6998.178 Electron/35.1.2 Safari/537.36" version="26.2.2">
  <diagram id="order_state_machine" name="订单状态机">
    <mxGraphModel dx="1030" dy="611" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="600" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="严谨的订单状态机 - 8个状态 · 12种转换 · 100%业务覆盖" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=16;fontStyle=1;align=center;" parent="1" vertex="1">
          <mxGeometry x="50" y="30" width="900" height="50" as="geometry" />
        </mxCell>
        <mxCell id="unpaid" value="未支付(UNPAID)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=12;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="80" y="150" width="100" height="60" as="geometry" />
        </mxCell>
        <mxCell id="paid" value="已支付(PAID)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="250" y="150" width="100" height="60" as="geometry" />
        </mxCell>
        <mxCell id="confirmed" value="已确认(CONFIRMED)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="420" y="150" width="100" height="60" as="geometry" />
        </mxCell>
        <mxCell id="ready" value="准备入住(READY_FOR_CHECKIN)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="590" y="150" width="120" height="60" as="geometry" />
        </mxCell>
        <mxCell id="checkedin" value="已入住(CHECKED_IN)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="760" y="150" width="100" height="60" as="geometry" />
        </mxCell>
        <mxCell id="completed" value="已完成\n(COMPLETED)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="760" y="280" width="100" height="60" as="geometry" />
        </mxCell>
        <mxCell id="cancelled" value="已取消(CANCELLED)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="80" y="280" width="100" height="60" as="geometry" />
        </mxCell>
        <mxCell id="refunding" value="退款中(REFUNDING)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=12;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="300" y="280" width="100" height="60" as="geometry" />
        </mxCell>
        <mxCell id="edge1" value="支付" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=classic;endFill=1;strokeColor=#82b366;strokeWidth=2;" parent="1" source="unpaid" target="paid" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge2" value="房东确认" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=classic;endFill=1;strokeColor=#6c8ebf;strokeWidth=2;" parent="1" source="paid" target="confirmed" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge3" value="入住时间到" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=classic;endFill=1;strokeColor=#9673a6;strokeWidth=2;" parent="1" source="confirmed" target="ready" edge="1">
          <mxGeometry relative="1" as="geometry" />
