        <mxCell id="edge8" value="房东取消" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=classic;endFill=1;strokeColor=#d79b00;strokeWidth=2;" parent="1" source="confirmed" target="refunding" edge="1">
          <mxGeometry relative="1" as="geometry">
