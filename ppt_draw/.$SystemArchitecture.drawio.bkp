<mxfile host="Electron" agent="Claude" version="1.0">
  <diagram id="system_architecture" name="简洁的系统架构设计">
    <mxGraphModel dx="1200" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- 标题 -->
        <mxCell id="title" value="分层解耦的系统架构 - 智能 + 安全 + 高效" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=18;fontStyle=1;align=center;" parent="1" vertex="1">
          <mxGeometry x="100" y="20" width="800" height="50" as="geometry" />
        </mxCell>

        <!-- 前端层 -->
        <mxCell id="frontend-layer" value="前端层 - Vue 3 + Element Plus" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=16;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="100" y="100" width="800" height="50" as="geometry" />
        </mxCell>
        
        <mxCell id="user-app" value="用户端\n房源浏览 · 预订支付 · 个人中心" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="150" y="170" width="250" height="80" as="geometry" />
        </mxCell>
        
        <mxCell id="admin-app" value="管理端\n房源审核 · 订单管理 · 数据统计" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="500" y="170" width="250" height="80" as="geometry" />
        </mxCell>

        <!-- 服务层 -->
        <mxCell id="service-layer" value="服务层 - Spring Boot 3 + Spring Security" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=16;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="100" y="300" width="800" height="50" as="geometry" />
        </mxCell>
        
        <mxCell id="core-services" value="核心业务服务\n• 用户认证与权限管理\n• 房源管理与智能推荐\n• 订单处理与支付集成\n• 审核工作流与通知系统" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="200" y="370" width="600" height="100" as="geometry" />
        </mxCell>

        <!-- 数据层 -->
        <mxCell id="data-layer" value="数据层 - 持久化与缓存" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=16;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="100" y="510" width="800" height="50" as="geometry" />
        </mxCell>
        
        <mxCell id="mysql" value="MySQL\n主数据库\n用户·房源·订单" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="200" y="580" width="180" height="80" as="geometry" />
        </mxCell>
        
        <mxCell id="redis" value="Redis\n缓存层\n会话·热点数据·分布式锁" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="420" y="580" width="180" height="80" as="geometry" />
        </mxCell>
        
        <mxCell id="storage" value="文件存储\n静态资源\n图片·文档" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="620" y="580" width="180" height="80" as="geometry" />
        </mxCell>

        <!-- 外部服务（简化为一个组件） -->
        <mxCell id="external-services" value="第三方服务\n支付系统 · 地图服务 · 短信通知" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="850" y="400" width="150" height="80" as="geometry" />
        </mxCell>

        <!-- 连接线（简化） -->
        <mxCell id="edge1" value="HTTPS/REST API" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=classic;endFill=1;fontSize=10;" parent="1" source="user-app" target="core-services" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        
        <mxCell id="edge2" value="HTTPS/REST API" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=classic;endFill=1;fontSize=10;" parent="1" source="admin-app" target="core-services" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        
        <mxCell id="edge3" value="JPA/JDBC" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=classic;endFill=1;fontSize=10;" parent="1" source="core-services" target="mysql" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        
        <mxCell id="edge4" value="Redis Template" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=classic;endFill=1;fontSize=10;" parent="1" source="core-services" target="redis" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        
        <mxCell id="edge5" value="API调用" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=classic;endFill=1;fontSize=10;" parent="1" source="core-services" target="external-services" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 技术特点标注 -->
        <mxCell id="tech-highlight" value="技术特点：分层解耦 · 微服务化 · 高并发 · 可扩展" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=14;fontStyle=1;align=center;" parent="1" vertex="1">
          <mxGeometry x="200" y="30" width="600" height="30" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile> 