# Admin frontend URL
VITE_ADMIN_BASE_URL=http://localhost:5174

# Show test accounts outside development only when explicitly enabled
VITE_SHOW_TEST_ACCOUNTS=false

# AMap Web JSAPI
VITE_AMAP_API_KEY=CHANGE_ME
VITE_AMAP_WEB_SERVICE_KEY=CHANGE_ME
VITE_AMAP_SECURITY_JS_CODE=CHANGE_ME

# Optional reverse proxy for AMap JSAPI secure service host
VITE_AMAP_SERVICE_HOST=
