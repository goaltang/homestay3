# ==========================================
# AI 大模型 API Keys（本地开发用）
# 复制本文件为 .env.local，然后填入真实 key
# .env.local 已被 .gitignore 忽略，不会提交到 Git
# ==========================================

# --- OpenAI ---
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.openai.com/v1

# --- Anthropic Claude ---
ANTHROPIC_API_KEY=sk-ant-xxx

# --- 阿里云通义千问 ---
DASHSCOPE_API_KEY=sk-xxx

# --- 百度文心一言 ---
QIANFAN_ACCESS_KEY=xxx
QIANFAN_SECRET_KEY=xxx

# --- 智谱 GLM / Zhipu ---
ZHIPU_API_KEY=xxx

# --- Kimi / Moonshot ---
MOONSHOT_API_KEY=sk-xxx

# --- DeepSeek ---
DEEPSEEK_API_KEY=sk-xxx

# --- Google Gemini ---
GOOGLE_API_KEY=xxx

# --- Azure OpenAI ---
AZURE_OPENAI_API_KEY=xxx
AZURE_OPENAI_ENDPOINT=https://xxx.openai.azure.com/

# --- SiliconFlow / 其他聚合平台 ---
SILICONFLOW_API_KEY=sk-xxx

# ==========================================
# 可选：AI 辅助编程工具配置
# ==========================================

# Aider 配置（如果命令行用 aider）
AIDER_MODEL=gpt-4o

# Kimi CLI 通常读取 ~/.kimi/config.json，但也可以通过环境变量覆盖
